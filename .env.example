# ADMIN_USER_IDS (optional): comma-separated user IDs pre-seeded as approved on
# startup, so an existing hand-picked allowlist keeps working.
ADMIN_USER_IDS=
# ACCESS_STORE_PATH (optional): where the JSON access store lives.
ACCESS_STORE_PATH=data/access.json

